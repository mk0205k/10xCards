---
import { createClient } from "@/lib/supabase";
import { m } from "@/paraglide/messages.js";

const invalidLinkUrl = `/auth/reset-password?error=${encodeURIComponent(m.auth_confirm_invalid_link())}`;

const tokenHash = Astro.url.searchParams.get("token_hash");
const type = Astro.url.searchParams.get("type");
const rawNext = Astro.url.searchParams.get("next") ?? "/auth/update-password";
const safeNext = rawNext.startsWith("/") && !rawNext.startsWith("//") ? rawNext : "/auth/update-password";

if (!tokenHash || type !== "recovery") {
  return Astro.redirect(invalidLinkUrl);
}

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) {
  return Astro.redirect(`/auth/reset-password?error=${encodeURIComponent(m.auth_confirm_supabase_not_configured())}`);
}

const { error } = await supabase.auth.verifyOtp({ type: "recovery", token_hash: tokenHash });
if (error) {
  return Astro.redirect(invalidLinkUrl);
}

return Astro.redirect(safeNext);
---
