---
import Layout from "@/layouts/Layout.astro";
import SignUpForm from "@/components/auth/SignUpForm";

const rawError = Astro.url.searchParams.get("error");
const isPendingDeletion = rawError === "account_pending_deletion";
const error = isPendingDeletion
  ? "Konto z tym mailem oczekuje na usunięcie. Zaloguj się, aby je przywrócić w ciągu 30 dni."
  : rawError;
---

<Layout title="Sign up">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Sign up
      </h1>
      <SignUpForm serverError={error} client:load />
      {
        isPendingDeletion && (
          <p class="mt-3 text-center text-sm text-blue-100/70">
            <a href="/auth/signin" class="text-purple-300 hover:underline">
              Zaloguj się, aby przywrócić konto
            </a>
          </p>
        )
      }
      <p class="mt-4 text-center text-sm text-blue-100/60">
        Already have an account? <a href="/auth/signin" class="text-purple-300 hover:underline">Sign in</a>
      </p>
    </div>
  </div>
</Layout>
