---
import Layout from "@/layouts/Layout.astro";
import { m } from "@/paraglide/messages.js";

const showInbucketHint = import.meta.env.DEV;
---

<Layout title={m.auth_reset_password_sent_title()}>
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div
      class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl"
    >
      <div class="mb-4 text-5xl">📧</div>
      <h1 class="mb-3 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
        {m.auth_reset_password_sent_title()}
      </h1>
      <p class="mb-6 text-blue-100/80">
        {m.auth_reset_password_sent_body()}
      </p>
      {
        showInbucketHint && (
          <p class="mb-6 text-xs text-blue-100/50">
            {m.auth_reset_password_sent_dev_hint_prefix()}{" "}
            <a href="http://127.0.0.1:54324" class="text-purple-300 hover:underline" target="_blank" rel="noopener">
              Inbucket
            </a>
            .
          </p>
        )
      }
      <a href="/auth/signin" class="text-sm text-purple-300 hover:underline"> {m.auth_reset_password_sent_back()} </a>
    </div>
  </div>
</Layout>
