---
import Layout from "@/layouts/Layout.astro";
import GeneratePanel from "@/components/generate/GeneratePanel";

const { user } = Astro.locals;
---

<Layout title="Generate flashcards">
  <div class="bg-cosmic min-h-screen p-4 md:p-8">
    <div class="mx-auto max-w-3xl space-y-6 text-white">
      <header class="rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
        <h1 class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Generate flashcards
        </h1>
        <p class="text-sm text-blue-100/70">
          Signed in as <span class="font-semibold text-white">{user?.email}</span>. Paste up to 10 000 characters below;
          proposals will stream in one-by-one.
        </p>
      </header>
      <GeneratePanel client:load />
    </div>
  </div>
</Layout>
